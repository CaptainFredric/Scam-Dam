# Copy to .env.local for local dev. Do NOT commit your real .env.local.
# These values are read at build time for Next.js public vars and at runtime
# for server-only ones.

# --- Public site URL (used in OG metadata, sitemap, robots, Stripe redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (auth + database + storage)
# Get these from your Supabase project settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server only. Used by the Stripe webhook to update
# user profiles. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (one per plan). Create them in Stripe -> Products and
# paste the price_xxx IDs here. Test-mode IDs in dev, live in prod.
STRIPE_PRICE_PACKET=price_...
STRIPE_PRICE_VAULT=price_...
STRIPE_PRICE_PRO=price_...

# --- Email (Resend). Optional — when unset, /api/cron/stalled-cases logs
# instead of sending. Get a key at resend.com.
RESEND_API_KEY=
# Override the default From address. Must be a domain you've verified in Resend.
EMAIL_FROM=

# --- Vercel Cron secret. Vercel sets this automatically when you add a cron;
# our /api/cron/* routes verify the bearer token to prevent abuse.
CRON_SECRET=

# --- GitHub Pages build (set automatically by .github/workflows/deploy-pages.yml).
# Do NOT set these locally unless you want to test the static export.
# GITHUB_PAGES=true
# PAGES_BASE_PATH=/Scam-Dam
